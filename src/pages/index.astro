// Farbe je km-Steigung
function segColor(g) { return g < 5 ? 'var(--c1)' : g < 7 ? 'var(--c2)' : g < 9 ? 'var(--c3)' : g < 11 ? 'var(--c4)' : g < 14 ? 'var(--c5)' : 'var(--c6)'; }

// km-Segmente konsistent aus Länge/Hm/Max erzeugen (Gauss-Bump nahe Max, Mittel = Ø, exakt auf Hm skaliert)
function buildSegs(c) {
  const n = Math.max(3, Math.round(c.length));
  const avg = c.hm / (c.length * 10);
  const peak = 0.62, sigma = 0.26;
  const raw = [];
  for (let i = 0; i < n; i++) {
    const t = n > 1 ? i / (n - 1) : 0;
    raw.push(avg + (c.max - avg) * Math.exp(-Math.pow(t - peak, 2) / (2 * sigma * sigma)));
  }
  const mean = raw.reduce((a, b) => a + b, 0) / n;
  let segs = raw.map((v) => Math.max(1.5, avg + (v - mean)));
  const sum = segs.reduce((a, b) => a + b, 0);
  const factor = (c.hm / 10) / sum; // exakt auf Hm normieren
  return segs.map((v) => v * factor);
}

// Datengenaues, km-für-km eingefärbtes Höhenprofil
function profileSegSVG(c) {
  const segs = buildSegs(c);
  const W = 460, H = 178, padL = 50, padR = 14, padT = 16, padB = 28;
  const innerW = W - padL - padR, innerH = H - padT - padB;
  const n = segs.length, base = Math.round(c.summit - c.hm);
  const elev = [base];
  for (let i = 0; i < n; i++) elev.push(elev[i] + segs[i] * 10);
  const top = elev[n], minE = base, range = (top - minE) || 1;
  const x = (k) => padL + (k / n) * innerW;
  const y = (e) => padT + (1 - (e - minE) / range) * innerH;
  const baseY = padT + innerH;
  let svg = '<svg class="profile" viewBox="0 0 ' + W + ' ' + H + '" role="img" aria-label="Höhenprofil ' + c.name + '">';
  [0.5, 1].forEach((g) => { const yy = padT + g * innerH; svg += '<line class="grid" x1="' + padL + '" y1="' + yy + '" x2="' + (padL + innerW) + '" y2="' + yy + '"/>'; });
  for (let i = 0; i < n; i++) {
    const x0 = x(i), x1 = x(i + 1), y0 = y(elev[i]), y1 = y(elev[i + 1]);
    svg += '<path d="M' + x0.toFixed(1) + ' ' + baseY + ' L' + x0.toFixed(1) + ' ' + y0.toFixed(1) + ' L' + x1.toFixed(1) + ' ' + y1.toFixed(1) + ' L' + x1.toFixed(1) + ' ' + baseY + ' Z" fill="' + segColor(segs[i]) + '" fill-opacity="0.85"/>';
  }
  let line = '';
  for (let i = 0; i <= n; i++) line += (i ? 'L' : 'M') + x(i).toFixed(1) + ' ' + y(elev[i]).toFixed(1) + ' ';
  svg += '<path d="' + line + '" fill="none" stroke="#16212e" stroke-width="1.4" stroke-opacity="0.5"/>';
  svg += '<text class="ax" x="' + (padL - 6) + '" y="' + (padT + 4) + '" text-anchor="end">' + c.summit.toLocaleString('de-DE') + ' m</text>';
  svg += '<text class="ax" x="' + (padL - 6) + '" y="' + baseY + '" text-anchor="end">' + minE.toLocaleString('de-DE') + ' m</text>';
  svg += '<text class="ax" x="' + padL + '" y="' + (H - 9) + '" text-anchor="start">0 km</text>';
  svg += '<text class="ax" x="' + (padL + innerW) + '" y="' + (H - 9) + '" text-anchor="end">' + c.length.toLocaleString('de-DE') + ' km</text>';
  svg += '</svg>';
  return svg;
}

const LEGEND = '<span><i style="background:var(--c1)"></i>&lt;5&nbsp;%</span><span><i style="background:var(--c2)"></i>5–7&nbsp;%</span><span><i style="background:var(--c3)"></i>7–9&nbsp;%</span><span><i style="background:var(--c4)"></i>9–11&nbsp;%</span><span><i style="background:var(--c5)"></i>11–14&nbsp;%</span><span><i style="background:var(--c6)"></i>&gt;14&nbsp;%</span>';

// SVG-Höhenprofil für einen Anstieg
function profileSVG(c, uid) {
  const W = 460, H = 168, padL = 50, padR = 18, padT = 18, padB = 30;
  const innerW = W - padL - padR;
  const innerH = H - padT - padB;
  const base = Math.round(c.summit - c.hm);
  const N = 56;
  const pts = [];
  for (let i = 0; i <= N; i++) {
    const t = i / N;
    const ease = 0.5 * (1 - Math.cos(Math.PI * t)); // monoton steigende S-Kurve
    const x = padL + t * innerW;
    const y = padT + (1 - ease) * innerH;
    pts.push([x, y]);
  }
  const line = pts.map((p, i) => (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ');
  const area = line + ` L ${(padL + innerW).toFixed(1)} ${(padT + innerH).toFixed(1)} L ${padL} ${(padT + innerH).toFixed(1)} Z`;
  const a = avgPct(c);
  const grid = [0.5, 0.75, 1].map((g) => {
    const y = padT + g * innerH;
    return `<line x1="${padL}" y1="${y.toFixed(1)}" x2="${padL + innerW}" y2="${y.toFixed(1)}" class="grid"/>`;
  }).join('');
  return `
  <svg viewBox="0 0 ${W} ${H}" class="profile" role="img" aria-label="Höhenprofil ${c.name}">
    <defs>
      <linearGradient id="g-${uid}" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--prof-${steepClass(a)})" stop-opacity="0.55"/>
        <stop offset="1" stop-color="var(--prof-${steepClass(a)})" stop-opacity="0.05"/>
      </linearGradient>
    </defs>
    ${grid}
    <path d="${area}" fill="url(#g-${uid})"/>
    <path d="${line}" fill="none" stroke="var(--prof-${steepClass(a)})" stroke-width="2.5" stroke-linejoin="round"/>
    <text x="${padL - 6}" y="${padT + 4}" class="ax" text-anchor="end">${fmt(c.summit)} m</text>
    <text x="${padL - 6}" y="${padT + innerH}" class="ax" text-anchor="end">${fmt(base)} m</text>
    <text x="${padL}" y="${H - 9}" class="ax" text-anchor="start">0 km</text>
    <text x="${padL + innerW}" y="${H - 9}" class="ax" text-anchor="end">${c.length.toLocaleString('de-DE')} km</text>
    <text x="${padL + innerW - 4}" y="${padT + 18}" class="bigpct ${steepClass(a)}" text-anchor="end">Ø ${pct(a)} %</text>
  </svg>`;
}

