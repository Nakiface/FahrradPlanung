// ---- Hilfsfunktionen ---------------------------------------
const fmt = (n) => n.toLocaleString('de-DE');
const pct = (x) => x.toFixed(1).replace('.', ',');
const avgPct = (c) => (c.hm / (c.length * 10));
const steepClass = (a) => (a < 6 ? 'easy' : a < 8 ? 'mid' : 'hard');

// SVG-Höhenprofil für einen Anstieg
function profileSVG(c, uid) {
  const W = 460, H = 168, padL = 50, padR = 18, padT = 18, padB = 30;
  const innerW = W - padL - padR;
  const innerH = H - padT - padB;
  const base = Math.round(c.summit - c.hm);
  const N = 56;
  const pts = [];
  for (let i = 0; i <= N; i++) {
    const t = i / N;
    const ease = 0.5 * (1 - Math.cos(Math.PI * t)); // monoton steigende S-Kurve
    const x = padL + t * innerW;
    const y = padT + (1 - ease) * innerH;
    pts.push([x, y]);
  }
  const line = pts.map((p, i) => (i ? 'L' : 'M') + p[0].toFixed(1) + ' ' + p[1].toFixed(1)).join(' ');
  const area = line + ` L ${(padL + innerW).toFixed(1)} ${(padT + innerH).toFixed(1)} L ${padL} ${(padT + innerH).toFixed(1)} Z`;
  const a = avgPct(c);
  const grid = [0.5, 0.75, 1].map((g) => {
    const y = padT + g * innerH;
    return `<line x1="${padL}" y1="${y.toFixed(1)}" x2="${padL + innerW}" y2="${y.toFixed(1)}" class="grid"/>`;
  }).join('');
  return `
  <svg viewBox="0 0 ${W} ${H}" class="profile" role="img" aria-label="Höhenprofil ${c.name}">
    <defs>
      <linearGradient id="g-${uid}" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--prof-${steepClass(a)})" stop-opacity="0.55"/>
        <stop offset="1" stop-color="var(--prof-${steepClass(a)})" stop-opacity="0.05"/>
      </linearGradient>
    </defs>
    ${grid}
    <path d="${area}" fill="url(#g-${uid})"/>
    <path d="${line}" fill="none" stroke="var(--prof-${steepClass(a)})" stroke-width="2.5" stroke-linejoin="round"/>
    <text x="${padL - 6}" y="${padT + 4}" class="ax" text-anchor="end">${fmt(c.summit)} m</text>
    <text x="${padL - 6}" y="${padT + innerH}" class="ax" text-anchor="end">${fmt(base)} m</text>
    <text x="${padL}" y="${H - 9}" class="ax" text-anchor="start">0 km</text>
    <text x="${padL + innerW}" y="${H - 9}" class="ax" text-anchor="end">${c.length.toLocaleString('de-DE')} km</text>
    <text x="${padL + innerW - 4}" y="${padT + 18}" class="bigpct ${steepClass(a)}" text-anchor="end">Ø ${pct(a)} %</text>
  </svg>`;
}

// Übersichts-Balkendiagramm: größter Anstieg (Hm) je Ort
const maxHm = locations.map((l) => ({ name: l.name, id: l.id, hm: Math.max(...l.climbs.map((c) => c.hm)) }));
const peakHm = Math.max(...maxHm.map((m) => m.hm));
